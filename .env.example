# Required: your personal Timepiece API token
# Get it from: Jira → Apps → Timepiece → API Settings → Create New Token
TIMEPIECE_TOKEN=your-token-uuid-here

# Optional: default Timepiece calendar ID to use for business-hours calculations
# Find calendar IDs in Jira → Apps → Timepiece → Settings → Calendars
TIMEPIECE_CALENDAR=10776

# Optional: default time counting method (businessDays or calendarDays)
TIMEPIECE_DEFAULT_DAY_LENGTH=businessDays

# Optional: default output unit (days, hours, minutes, seconds)
TIMEPIECE_DEFAULT_VIEW_FORMAT=days
